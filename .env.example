# Copy this file to .env and fill in your Supabase project credentials.
# Find them in your Supabase dashboard under Project Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: route the utility "functions" (cors-proxy, soccer, stock providers)
# to the self-hosted Node backend (the toolbox-backend repo) instead of Supabase
# edge functions. Point it at your tunnel hostname, including the /functions/v1
# path, no trailing slash. Leave unset to keep using Supabase edge functions.
#   VITE_FUNCTIONS_URL=https://api.your-domain.com/functions/v1
# VITE_FUNCTIONS_URL=

# Optional: base URL of the self-hosted cinepro-core backend that powers the
# Movies & TV tool's playback (the cinepro/ deployment in the toolbox-backend
# repo). Just the origin — no /v1, no trailing slash. Leave unset to disable
# playback (browsing still works).
#   VITE_CINEPRO_URL=https://cine.your-domain.com
# VITE_CINEPRO_URL=
