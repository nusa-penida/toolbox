# Copy to server/.env (or set these in the systemd unit). All optional.

# Port the backend listens on (loopback). The Cloudflare Tunnel points here.
PORT=8787

# Interface to bind. Keep loopback — the tunnel connects locally; nothing needs
# to be exposed on the LAN or a public port.
HOST=127.0.0.1

# CORS allow-origin. Defaults to "*" to match the old Supabase edge functions.
# Set it to your site's origin to lock the backend to your frontend only. Accepts
# a comma-separated list (e.g. apex + www + Pages URL); the backend reflects
# whichever origin matches, since CORS allows only one origin per response.
# ALLOW_ORIGIN=https://www.example.com,https://example.com
